<?xml version="1.0" encoding="UTF-8" standalone="no"?>

<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.2.xsd">
  <changeSet author="nveces@gmail.com" id="v3-create-table-advisor">
    <createTable tableName="advisor">
      <column name="id" type="BIGINT" autoIncrement="true">
        <constraints primaryKey="true" nullable="false" />
      </column>
      <column name="full_name" type="VARCHAR(255)">
        <constraints nullable="false" />
      </column>
      <column name="license_number" type="VARCHAR(50)">
        <constraints unique="true" nullable="false" />
      </column>
      <column name="status" type="VARCHAR(20)" defaultValue="ACTIVE">
        <constraints nullable="false" />
      </column>
      <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" />
    </createTable>
    <rollback>
      <dropTable tableName="advisor" />
    </rollback>
  </changeSet>
  <changeSet id="force-error-test" author="testing">
    <sql>SELECT * FROM throw_an_error;</sql>
  </changeSet>
</databaseChangeLog>