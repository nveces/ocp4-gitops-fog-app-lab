<?xml version="1.0" encoding="UTF-8" standalone="no"?>

<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.2.xsd">
  <changeSet author="nveces@gmail.com" id="v2-post-populate-currency">
    <update tableName="operation">
      <column name="currency_id" value="EUR" />
        <where>currency_id IS NULL</where>
    </update>
  </changeSet>
  <changeSet author="nveces@gmail.com" id="v2-post-null-constraint">
    <addNotNullConstraint tableName="operation"
      columnName="currency_id"
      columnDataType="VARCHAR(3)" />
  </changeSet>
</databaseChangeLog>